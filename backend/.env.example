# SPECTRAVEIN Backend — Environment Variables
# Copy this file to .env and load it before starting uvicorn,
# or set these as Environment Variables in your Render/Railway project settings.

# Comma-separated list of allowed frontend origins for CORS.
# Add your Vercel deployment URL here in production.
# Example: ALLOWED_ORIGINS=https://spectravein.vercel.app,https://www.spectravein.app
ALLOWED_ORIGINS=http://localhost:3000
